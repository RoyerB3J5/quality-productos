---
// Popup.astro
---

<link rel="preconnect" href="https://link.qualityportablerentalservice.com" />
<link rel="dns-prefetch" href="https://link.qualityportablerentalservice.com" />

<div
  id="popup-overlay"
  class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50"
  aria-modal="true"
  role="dialog"
>
  <div
    id="popup-box"
    class="bg-[#F9F8FD] rounded-2xl p-6 3xl:p-8 relative shadow-2xl flex flex-col justify-center items-center gap-0 3xl:gap-4 translate-y-5 transition-transform duration-200 max-h-[95%] 3xl:max-h-[90%] w-[95%] md:w-[75%] lg:w-[65%] xl:w-[50%] 3xl:w-[40%] border-4 border-primary overflow-hidden"
  >
    <button
      class="popup-close absolute top-4 right-4 text-2xl leading-none text-gray-400 hover:text-gray-900 transition-colors cursor-pointer bg-transparent border-none"
      aria-label="Cerrar"
    >
      &times;
    </button>
    <img
          src="/images/logo-popup.svg"
          alt="Logo de Quality Portable"
          width="180"
          height="55"
          class="cursor-pointer w-25 sm:w-30 3xl:w-45 h-auto block lg:hidden 3xl:block "
        />
    <div class="flex justify-center items-center flex-col gap-2 text-black mt-2 sm:mt-3 lg:mt-0">
      <h3 class="text-[24px] md:text-[36px] 3xl:text-[60px] font-bold leading-[125%] text-center ">Wait!</h3>
      <p class="text-[16px] md:text-[18px] 3xl:text-[34px] font-bold leading-[125%] text-center ">Don't Leave Without Your FREE Quote!</p>
      <p class="text-[14px] md:text-[16px] 3xl:text-[21px] font-normal leading-[125%] block lg:hidden text-center">Fill Out The Form Below To Get Your Free Quote</p>
    </div>
    <div class="relative w-full h-auto max-h-[530px] 3xl:max-h-[500px]">
      <div id="spinner" class="absolute inset-0 z-10 flex items-center justify-center">
        <svg
          class="animate-spin h-8 w-8 text-gray-500"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
        >
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
        </svg>
      </div>
      <iframe
        src="https://link.qualityportablerentalservice.com/widget/form/NtoETnPjnusVegXt6Cvb"
        class="w-full border-none relative z-40"
        id="inline-NtoETnPjnusVegXt6Cvb"
        data-layout="{'id':'INLINE'}"
        data-trigger-type="alwaysShow"
        data-trigger-value=""
        data-activation-type="alwaysActivated"
        data-activation-value=""
        data-deactivation-type="neverDeactivate"
        data-deactivation-value=""
        data-form-name="Form Landing Page"
        data-height="539"
        data-layout-iframe-id="inline-NtoETnPjnusVegXt6Cvb"
        data-form-id="NtoETnPjnusVegXt6Cvb"
        title="Form Landing Page"
        style="height: 539px;"
        onload="document.getElementById('spinner')?.style.setProperty('display','none')"
        sandbox="allow-forms allow-scripts allow-popups allow-same-origin allow-top-navigation-by-user-activation"
      ></iframe>
      <script src="https://link.qualityportablerentalservice.com/js/form_embed.js"></script>
    </div>
  </div>
</div>

<script>
  const overlay = document.getElementById('popup-overlay')!;
  const box = document.getElementById('popup-box')!;
  const closeBtn = overlay.querySelector('.popup-close')!;

  function openPopup() {
    overlay.classList.remove('hidden');
    overlay.classList.add('flex');
    box.classList.remove('translate-y-5');
    box.classList.add('translate-y-0');
    document.body.style.overflow = 'hidden';
  }

  function closePopup() {
    overlay.classList.add('hidden');
    overlay.classList.remove('flex');
    box.classList.add('translate-y-5');
    box.classList.remove('translate-y-0');
    document.body.style.overflow = '';
  }

  document.addEventListener('click', (e) => {
    const btn = (e.target as Element).closest('.open-popup');
    if (btn) openPopup();
  });

  closeBtn.addEventListener('click', closePopup);

  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) closePopup();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closePopup();
  });
</script>