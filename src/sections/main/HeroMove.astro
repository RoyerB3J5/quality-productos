---
import Button from '../../components/Button.astro';

type Translations = typeof import('../../i18n/en').default;
type HeroContent = Translations['main']['hero'];
interface Props {
  content: HeroContent;
}
const { content } = Astro.props as Props;

// Personalizar object-position para sm para abajo basado en el sufijo de la URL
const pathname = Astro.url.pathname;
const pagePositions: { [key: string]: { mobile: string; sm: string } } = {
  'hero-main': { mobile: '50% 0%', sm: '50% 5%' }, 
  'locations-hero': { mobile: '62% 50%', sm: '50% 80%' },
  'orlando-hero': { mobile: '50% 90%', sm: '50% 80%' },
  'melbourne-hero': { mobile: '45% 50%', sm: '50% 80%' },
  'tampa-hero': { mobile: '35% 50%', sm: '50% 80%' }, 
  'fort-myers-hero': { mobile: '55% 50%', sm: '50% 80%' },
  'products-hero': { mobile: '50% 90%', sm: '50% 80%' },
  'services-hero': { mobile: '45% 50%', sm: '50% 80%' },
  'industries-hero': { mobile: '35% 50%', sm: '50% 80%' }, 
};

// Mapa global de imágenes para cuando cambian dinámicamente
const imagePositions: { [key: string]: { mobile: string; sm: string } } = {
  'hero-main': { mobile: '50% 0%', sm: '50% 5%' }, 
  'locations-hero': { mobile: '62% 50%', sm: '50% 80%' },
  'orlando-hero': { mobile: '50% 90%', sm: '50% 80%' },
  'melbourne-hero': { mobile: '45% 50%', sm: '50% 80%' },
  'tampa-hero': { mobile: '35% 50%', sm: '50% 80%' }, 
  'fort-myers-hero': { mobile: '55% 50%', sm: '50% 80%' },
  'products-hero': { mobile: '50% 90%', sm: '50% 80%' },
  'services-hero': { mobile: '45% 50%', sm: '50% 80%' },
  'industries-hero': { mobile: '35% 50%', sm: '50% 80%' }, 
};

let smallObjectPosition = { mobile: '68% 50%', sm: '50% 80%' }; // default para otras páginas
for (const [suffix, position] of Object.entries(pagePositions)) {
  if (pathname.endsWith(suffix)) {
    smallObjectPosition = position;
    break;
  }
}
---

<section class="w-full flex items-center justify-center relative overflow-hidden">
  <img
    src={`/images/${content.imagesLoop[0].img}.webp`}
    alt={content.title}
    width="2500"
    height="1563"
    class={`absolute inset-0 w-full h-full object-cover -z-20 3xl:object-[50%_60%] translate-y-[-20%] sm:translate-y-0 img-hero transition-opacity duration-500 ease-in-out `}
    loading="eager"
    decoding="async"
    id="hero-bg"
    data-images={JSON.stringify(content.imagesLoop.map(img => img.img))}
    data-positions={JSON.stringify(imagePositions)}
    style={`--object-pos-mobile: ${smallObjectPosition.mobile}; --object-pos-sm: ${smallObjectPosition.sm}`}
  />
  <div class="absolute h-full w-full -z-15 bg-[linear-gradient(180deg,rgba(0,0,0,0.00)_49.08%,#000_80.39%)] sm:bg-none"></div>
  
  <div
    class="w-full max-w-screen md:max-w-7xl flex flex-row justify-start items-end sm:items-start gap-4 md:gap-10 px-5 xl:px-0 h-dvh md:h-[90vh] lg:h-screen pt-0 sm:pt-[10%] md:pt-[7%] lg:pt-[4%] pb-10 sm:pb-0 hero-content"
  >
    <div
      class="flex flex-col items-start justify-center w-full max-w-none lg:max-w-[70%] gap-6 md:gap-4 md:translate-y-10"
    >
      <h1
        class={`text-white dark:text-paragraph-dark  
        text-[36px] md:text-[60px] 3xl:text-[64px] 
        font-extrabold leading-[122%] md:leading-[114%] `}
        id="hero-title-main"
        data-services={JSON.stringify(content.services || [])}
        data-images={JSON.stringify(content.imagesLoop.map(img => img.img))}
      >
        <span set:html={content.title}></span>
        <span class="inline-block overflow-hidden align-top h-[1.2em]" id="service-carousel-container">
          <div id="services-list" class="transition-transform" style="transform: translateY(0)">
            {content.services?.map((service) => (
              <div class="h-[1.2em] leading-[122%] md:leading-[114%] text-accent  dark:text-primary-dark ">
                {service}
              </div>
            ))}
          </div>
        </span>
      </h1>
      <p id="hero-description" data-image={content.imagesLoop[0].img} class="text-white text-[14px] md:text-[16px] font-normal leading-[143%] md:leading-[150%] max-w-100.25 " set:html={content.description}></p>
      <div class="flex justify-between sm:justify-start items-center gap-4 w-full sm:w-auto">
        {
          content.buttons.map((item)=>( 
            <Button
              text={item.label}
              textClass={item.text}
              href={item.href}
              extraBtnClass={item.back}
              iconName={item.icon}
            />
          ))
        }
      </div>
    </div>
  </div>
</section>
<style>
  .img-hero {
    object-position: var(--object-pos-mobile, 46% 50%);
  }
  
  @media (min-width: 640px) {
    .img-hero {
      object-position: var(--object-pos-sm, 50% 80%);
    }
  }
</style>
<script is:inline>
  const heroBg = document.getElementById('hero-bg')
  const imagesDataAttr = heroBg?.getAttribute('data-images')
  const positionsDataAttr = heroBg?.getAttribute('data-positions')
  const imagesArray = imagesDataAttr ? JSON.parse(imagesDataAttr) : ['hero-main']
  const positionsMap = positionsDataAttr ? JSON.parse(positionsDataAttr) : {}

  let currentImageIndex = 0
  let isTransitioning = false

  // Convertir clase Tailwind object-[X%_Y%] a CSS válido (X% Y%)
  function convertTailwindToCSS(tailwindClass) {
    if (!tailwindClass) return 'center'
    const match = tailwindClass.match(/object-\[(.*?)\]/)
    if (match) {
      // Convertir 'object-[68%_50%]' → '68% 50%'
      return match[1].replace(/_/g, ' ')
    }
    return 'center'
  }

  // Función para actualizar object-position según la imagen
  function updateObjectPosition(imageName) {
    // Buscar primero el nombre exacto de la imagen
    let positionConfig = positionsMap[imageName]
    
    // Si no existe, intentar con 'default'
    if (!positionConfig) {
      positionConfig = positionsMap['default']
    }
    
    // Si aún no existe, usar valores por defecto
    if (!positionConfig) {
      positionConfig = { mobile: '50% 50%', sm: '50% 80%' }
    }
    
    heroBg.style.setProperty('--object-pos-mobile', positionConfig.mobile)
    heroBg.style.setProperty('--object-pos-sm', positionConfig.sm)
  }

  // Aplicar object-position en la carga inicial
  updateObjectPosition(imagesArray[currentImageIndex])

  // Cambiar imagen cada 10 segundos
  setInterval(() => {
    if (heroBg && !isTransitioning && imagesArray.length > 0) {
      isTransitioning = true
      
      // Desvanecer la imagen
      heroBg.style.opacity = '0'
      
      // Cambiar la imagen después de que desaparezca
      setTimeout(() => {
        // Incrementar índice PRIMERO
        currentImageIndex = (currentImageIndex + 1) % imagesArray.length
        const newImage = imagesArray[currentImageIndex]
        
      // Cambiar la imagen
      heroBg.src = `/images/${newImage}.webp`
      
      // Actualizar el atributo data-image del párrafo
      const descriptionEl = document.getElementById('hero-description')
      if (descriptionEl) {
        descriptionEl.setAttribute('data-image', newImage)
      }
      
      // Aplicar la posición correcta basada en la imagen
      updateObjectPosition(newImage)
      
      // Mostrar la nueva imagen
      heroBg.style.opacity = '1'
      
      // Fin de transición
      isTransitioning = false
      }, 250)
    }
  }, 12000)

  // Efecto Parallax para la sección Hero
  document.addEventListener('DOMContentLoaded', () => {
    const heroBg = document.getElementById('hero-bg');
    const heroSection = heroBg?.closest('section');

    if (!heroBg || !heroSection) return;

    // Mejora de rendimiento: usar requestAnimationFrame + listener passive
    heroBg.style.willChange = 'transform';

    let ticking = false;
    let parallaxActive = true;

    function updateParallax() {
      if (!heroBg || !heroSection || !parallaxActive) {
        ticking = false;
        return;
      }

      const rect = heroSection.getBoundingClientRect();
      // Si no está visible, no actualizar
      if (rect.bottom <= 0 || rect.top >= window.innerHeight) {
        ticking = false;
        return;
      }

      // Calcular desplazamiento relativo a la sección para suavizar el efecto
      const scrolled = Math.max(0, window.pageYOffset - heroSection.offsetTop);
      const isMobile = window.innerWidth < 640;
      const parallaxMultiplier = isMobile ? 0.75 : 0.6;
      const parallaxValue = scrolled * parallaxMultiplier;

      // Usar translate3d para activar la GPU y mejorar fluidez
      heroBg.style.transform = `translate3d(0, ${parallaxValue}px, 0)`;
      ticking = false;
    }

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(updateParallax);
        ticking = true;
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });

    // IntersectionObserver para pausar cuando la sección no está en pantalla
    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        parallaxActive = entry.isIntersecting;
      });
    }, { threshold: 0 });

    io.observe(heroSection);

    // Aplicar una vez al cargar
    requestAnimationFrame(updateParallax);
  });

  document.addEventListener('DOMContentLoaded', () => {
    const titleElement = document.getElementById('hero-title-main')
    const servicesList = document.getElementById('services-list')
    const serviceContainer = document.getElementById('service-carousel-container')

    const servicesData = titleElement?.getAttribute('data-services')
    const services = servicesData ? JSON.parse(servicesData) : []

    if (services.length === 0 || !servicesList || !serviceContainer) return

    let currentServiceIndex = 0
    const lineHeight = serviceContainer.offsetHeight // Altura de una línea

    // Aplicar transición
    servicesList.style.transition = 'transform 500ms cubic-bezier(0.4, 0, 0.2, 1)'

    setInterval(() => {
      currentServiceIndex = (currentServiceIndex + 1) % services.length
      // Trasladar el contenedor hacia arriba
      servicesList.style.transform = `translateY(-${currentServiceIndex * lineHeight}px)`
    }, 2000)
  })

</script>
