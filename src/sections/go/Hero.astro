---
type Translations = typeof import('../../i18n/en').default;
type HeroContent = Translations['landingFirst']['hero'];
interface Props {
  content: HeroContent;
  second?: boolean;
}
const { content, second } = Astro.props as Props;
---
<section class="w-full flex flex-col items-center justify-center relative overflow-hidden h-dvh md:h-[90vh] lg:h-screen">
  <div class="w-full relative overflow-hidden flex justify-center items-center h-full">
    <img src="/images/back-started.webp" alt="Fondo de Hero Landing" width="1500" height="705" class="absolute inset-0 w-full h-full object-cover object-center -z-20">
    <div class={`absolute h-full w-full -z-15 ${second ? 'bg-[linear-gradient(0deg,rgba(0,0,0,0.70)_0%,rgba(0,0,0,0.70)_100%)]' : 'bg-[linear-gradient(0deg,rgba(0,0,0,0.55)_0%,rgba(0,0,0,0.55)_100%)]'}  `}></div>
    <div
      class={`container-full flex flex-col justify-center  items-center   text-white h-full pb-10 3xl:pb-20 translate-y-[3%] ${second ? 'gap-15 md:gap-4  lg:translate-y-[6%]' : 'gap-15 md:gap-8 3xl:gap-16 xl:justify-end lg:translate-y-0 '}`}
    >
      <div class={`flex flex-col justify-center items-center  ${second ? 'gap-6 md:gap-15' : 'gap-6'}`}>
        <h1 class={`text-[32px]  font-extrabold leading-[110%] text-center ${second ? 'md:text-[64px] lg:text-[80px]' : 'md:text-[46px] 3xl:text-[53px]'} `} set:html={content.title}> </h1>
        <p class={` leading-[100%] text-center ${second ? 'text-[18px] md:text-[28px] md:lg:text-[32px] font-bold md:font-black' : 'text-[18px] md:text-[26px] font-bold'} `} set:html={content.description}></p>
      </div>
      <div class="flex flex-col justify-center items-center gap-10">
        <div class={`flex flex-col justify-center items-start gap-4 ${content.items.length > 0 ? 'block' : 'hidden'}`}>
          {
            content.items.map((item)=>( 
              <div class="flex justify-start items-center gap-2 md:gap-4">
                <img src="/images/check-o.svg" alt="Check" width="32" height="32" class="w-6 md:w-8 h-6 md:h-8">
                <p class="text-[18px] md:text-[24px] 3xl:text-[28px] font-bold leading-normal">{item}</p>
              </div>
            ))
          }
        </div>
        <div class="flex flex-col md:flex-row md:justify-center items-center gap-10 md:gap-6">
          <button class={`animate-bounce open-popup bg-accent ${second ? 'h-14 md:h-17.75 leading-normal' : 'py-4 md:py-1 leading-[100%] md:leading-[187%]'}  px-8 rounded-lg flex justify-center items-center text-white text-[20px] md:text-[26px] 3xl:text-[32px] font-bold  hover:bg-primary transition-all duration-300 ease-in-out cursor-pointer`}>
            {content.button}
          </button>
          {
            second && <a class="animate-bounce px-8 rounded-lg flex justify-center items-center gap-2.5 text-white text-[20px] md:text-[32px] transition-all duration-300 ease-in-out cursor-pointer border border-white box-border  leading-[100%] h-14 md:h-17.75 font-bold" href="tel:+13212179445">
              <img src={`/images/phone-2.svg`} alt="Icono de telefono" class="w-6 md:w-8 h-6 md:h-8">
              <p>(321) 217-9445</p>
            </a>
          }
        </div>
      </div>
    </div>
  </div>
  {
    second ? null : (
      <div class="bg-primary flex flex-col justify-center items-center gap-2 text-white py-8 md:py-6 3xl:py-8 w-full">
        <h2 class="text-[24px] md:text-[28px] 3xl:text-[32px] font-bold leading-[140%] md:leading-[106%]">{content.callAction.title}</h2>
        <div class="flex justify-center items-center gap-2.5">
          <img src={`/images/${content.callAction.icon}.svg`} alt="Icono de telefono" class="w-auto h-auto">
          <a href="tel:+13212179445" class="text-[24px] font-bold leading-[150%] cursor-pointer hover:-translate-y-1 transition-all duration-300 ease-in-out">{content.callAction.number}</a>
        </div>
      </div>
    )
  }
  
</section>