---
type Translations = typeof import('../../i18n/en').default;
type IconsContent = Translations['landingFirst']['icons'];
interface Props {
  content: IconsContent;
}
const { content} = Astro.props as Props;
---
<section class="w-full flex justify-center items-center bg-primary">
    <div class="container-full grid grid-cols-1 md:grid-cols-4 justify-center items-center py-10.5 divide-x-0 md:divide-x-2 divide-[#0024C9] gap-8 md:gap-0">
    {
      content.map((item)=>( 
        <div class="flex flex-col justify-center items-center gap-6 md:px-7">
          <img src={`/images/${item.icon}.svg`} alt={item.title} width="60" height="60" class="w-15 md:w-15 h-15 md:h-15">
          <p class="text-[20px] leading-[117%] font-bold text-white text-center">{item.title}</p>
        </div>
      ))
    }
  </div>
</section>