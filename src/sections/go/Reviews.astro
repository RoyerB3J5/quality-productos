---
type Translations = typeof import('../../i18n/en').default;
type ReviewContent = Translations['landingFirst']['reviews'];
interface Props {
  content: ReviewContent;
  second:boolean
}
const { content,second } = Astro.props as Props;
const title = second ? content.title2 : content.title
---
<section class={`flex justify-center items-center w-full relative overflow-hidden ${second ? 'bg-[#F9F8FD]' : 'bg-[#FFF]'}`}>
  <div class="container-full flex flex-col justify-center items-center gap-10 md:gap-20 py-10 md:py-20">
    <h2 class="text-[32px] md:text-[56px] font-bold leading-[114%] text-primary text-center">{title}</h2>
    <div class="w-full md:grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 justify-center items-stretch gap-6 hidden ">
      {
        content.items.map((item)=>( 
          <div class={`grow w-full flex flex-col justify-start items-center gap-4 px-6 py-10 border border-[#E6E6E6] rounded-2xl shadow-solution ${second ? 'bg-white' : 'bg-[#F9F8FD]'}  `}>
            <img src={`/images/${item.image}.svg`} alt="Persona de Review" width="100" height="100" class="w-24 h-24 ">
            <div class="flex flex-col justify-center items-center gap-1.5">
              <h3 class="text-[18px] leading-[155%] font-bold text-primary">{item.title}</h3>
              <p class="text-[14px] leading-[155%] font-normal text-[#808080]">{item.date}</p>
              <div class="flex justify-center items-center gap-2">
                {
                  Array(5).fill(0).map((_)=>(
                    <img src="/images/star-2.svg" alt="Star" width="20" height="20" class="w-8 h-8">
                  ))
                }
              </div>
              <p class="text-[20px] leading-[155%] font-normal text-paragraph text-center">{item.description}</p>
            </div>
          </div>
        ))
      }
    </div>
    <div class="w-full grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 justify-center items-stretch gap-6 md:hidden ">
      {
        content.items.slice(0,3).map((item)=>( 
          <div class={`grow w-full flex flex-col justify-start items-center gap-4 px-6 py-10 border border-[#E6E6E6] rounded-2xl shadow-solution ${second ? 'bg-white' : 'bg-[#F9F8FD]'}  `}>
            <img src={`/images/${item.image}.svg`} alt="Persona de Review" width="100" height="100" class="w-24 h-24 ">
            <div class="flex flex-col justify-center items-center gap-1.5">
              <h3 class="text-[18px] leading-[155%] font-bold text-primary">{item.title}</h3>
              <p class="text-[14px] leading-[155%] font-normal text-[#808080]">{item.date}</p>
              <div class="flex justify-center items-center gap-2">
                {
                  Array(5).fill(0).map((_)=>(
                    <img src="/images/star-2.svg" alt="Star" width="20" height="20" class="w-8 h-8">
                  ))
                }
              </div>
              <p class="text-[20px] leading-[155%] font-normal text-paragraph text-center">{item.description}</p>
            </div>
          </div>
        ))
      }
    </div>
    {
      second && (
        <button class="bg-accent py-1 px-8 rounded-lg flex justify-center items-center text-white text-[26px] 3xl:text-[32px] font-bold leading-[187%] hover:bg-primary transition-all duration-300 ease-in-out cursor-pointer">
            {content.button}
          </button>
      )
    }
  </div>
  
  
</section>