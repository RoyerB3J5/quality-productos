---
type Translations = typeof import('../../i18n/en').default;
type AreasContent = Translations['landingSecond']['areas'];
interface Props {
  content: AreasContent;
}
const { content} = Astro.props as Props;
---
<section class="flex flex-col justify-center items-center   bg-[#F9F8FD] w-full">
  <div class="container-full py-10 md:py-20 gap-10 md:gap-20 flex flex-col justify-center items-center">
    <h2 class="text-primary text-[32px] md:text-[56px] font-bold leading-[114%] ">{content.title}</h2>
    <div class="flex justify-center items-stretch gap-6 w-full">
      <div class="w-full md:w-auto flex flex-col justify-center items-center gap-6">
        {
          content.items.map((item)=>( 
            <div class="w-full md:w-auto flex flex-col justify-center items-start gap-3 p-4 bg-white rounded-2xl shadow-solution">
              <p class="text-[20px] text-primary font-bold leading-normal ">{item.label}</p>
              <a href={item.link.href} class="flex justify-center items-center gap-2 cursor-pointer group bg-[#F4F1FF] rounded-lg p-2 w-full md:w-auto">
                  <img src="/images/circle-a.svg" alt="Arrow circle" width="24" height="24" class="w-6 h-6"/>
                  <p class={`text-[20px] font-normal leading-[150%] group-hover:text-primary transition-all duration-300 ease-in-out `}>{item.link.label}</p>
                </a>
            </div>
          ))
        }
      </div>
      <div class="flex-1  relative rounded-2xl overflow-hidden hidden md:block">
        <img src="/images/landing-map.webp" alt="Mapa de Quality" width="1200" height="1038" class="w-full h-full object-cover object-center absolute inset-0">
      </div>
    </div>
  </div>
</section>