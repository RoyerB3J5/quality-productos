---
type Translations = typeof import('../../i18n/en').default;
type ChooseContent = Translations['landingSecond']['choose'];
interface Props {
  content: ChooseContent;
}
const { content} = Astro.props as Props;
---
<section class="flex flex-col justify-center items-center gap-20 py-20 container-full">
  <div class="w-full flex flex-col md:flex-row justify-center items-center gap-8">
    <div class="flex flex-col justify-center items-start gap-10 w-full md:w-[65%] lg:w-[40%] order-2 md:order-1">
      <h2 class="text-[32px] md:text-[56px] text-primary font-bold leading-[114%]">{content.title}</h2>
      <p class="text-paragraph text-[19px] md:text-[20px] leading-[150%] font-normal">{content.description}</p>
      <button class="animate-bounce open-popup bg-accent p-4 md:p-3 xl:p-4 rounded-lg flex justify-center items-center text-white text-[20px] md:text-[16px] xl:text-[20px] font-bold leading-normal hover:bg-primary transition-all duration-300 ease-in-out cursor-pointer">
                {content.button}
      </button>
    </div>
    <div class="w-full md:w-[35%] lg:w-[60%] grid grid-cols-1 lg:grid-cols-2 justify-center items-center gap-6 order-1 md:order-2">
      <div class="w-full grid grid-cols-1 justify-center items-center gap-6">
        <div class="relative aspect-342/250 w-full h-auto rounded-2xl overflow-hidden">
          <img src="/images/large_3.webp" alt="Choose 1" width="342" height="250" class="w-full h-full absolute inset-0 object-center object-cover">
        </div>
        <div class="relative aspect-342/250 w-full h-auto rounded-2xl overflow-hidden">
          <img src="/images/choose-1.webp" alt="Choose 2" width="342" height="250" class="w-full h-full absolute inset-0 object-center object-cover">
        </div>
      </div>
      <div class="w-full lg:grid grid-cols-1 justify-center items-center gap-6 hidden ">
        <div class="relative aspect-342/250 w-full h-auto rounded-2xl overflow-hidden">
          <img src="/images/private_5.webp" alt="Choose 3" width="342" height="250" class="w-full h-full absolute inset-0 object-center object-cover">
        </div>
        <div class="relative aspect-342/250 w-full h-auto rounded-2xl overflow-hidden">
          <img src="/images/private_3.webp" alt="Choose 4" width="342" height="250" class="w-full h-full absolute inset-0 object-center object-cover">
        </div>
      </div>
    </div>
  </div>
  <div class="w-full md:flex justify-between items-center hidden ">
    {
      content.icons.map((icon)=>( 
        <div class="flex flex-col justify-center items-center gap-6">
          <img src={`/images/${icon.icon}.svg`} alt={icon.title} width="48" height="48" class="h-7.25 w-auto"/>
          <p class="text-[20px] text-primary leading-[117%] font-bold">{icon.title}</p>
        </div>
      ))
    }
  </div>
</section>