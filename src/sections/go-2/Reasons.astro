---
type Translations = typeof import('../../i18n/en').default;
type ReasonsContent = Translations['landingSecond']['reasons'];
interface Props {
  content: ReasonsContent;
}
const { content} = Astro.props as Props;
---
<section class="w-full flex justify-center items-center bg-primary">
  <div class="container-full flex flex-col justify-center items-center gap-10 md:gap-14 py-10 md:py-20">
    <h2 class="text-[32px] md:text-[56px] text-white font-bold leading-[114%] text-center" set:html={content.title}></h2>
    <div class="w-full grid grid-cols-1 lg:grid-cols-3 justify-center items-stretch gap-4 ld:gap-6">
      {
        content.items.map((item, index)=> {
          return (
            <div class="flex flex-col md:flex-row lg:flex-col justify-center items-center rounded-2xl overflow-hidden grow">
              <div class="aspect-384/320 md:aspect-auto lg:aspect-384/320 w-full md:w-[40%] h-auto md:h-full lg:w-full lg:h-auto relative">
                <img src={`/images/${item.image}.webp`} alt={item.title} width="384" height="320" class="absolute h-full w-full inset-0 object-cover object-center">
              </div>
              <div class="w-full md:w-[60%] lg:w-full bg-white flex flex-col justify-start items-start gap-4 p-4 md:px-8 md:py-6 grow">
                <p class="text-[48px] text-primary font-bold leading-[100%]">{index + 1}</p>
                <h3 class="text-[24px] font-bold leading-[150%] text-paragraph">{item.title}</h3>
                <p class="text-[19px] md:text-[20px] leading-[150%] text-paragraph font-normal">{item.description}</p>
              </div>
            </div>
          )
        })
      }
    </div>
  </div>
</section>