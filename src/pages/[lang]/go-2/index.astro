---
import en from '../../../i18n/en';
import es from '../../../i18n/es';
import LayoutLanding from '../../../layouts/LayoutLanding.astro';
import Products from '../../../sections/go-2/Products.astro';
import Services from '../../../sections/go-2/Services.astro';
import Hero from '../../../sections/go/Hero.astro';
import Map from '../../../sections/go-2/Map.astro';
import type { Language } from '../../../types/language.type';
import Reasons from '../../../sections/go-2/Reasons.astro';
import Choose from '../../../sections/go-2/Choose.astro';
import Footer from '../../../sections/go-2/Footer.astro';
import Customers from '../../../sections/go-2/Customers.astro';
import PopupAzul from '../../../components/PopupAzul.astro';
export function getStaticPaths() {
  return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }];
}

export const defaultRedirect = '/en';

const lang = Astro.params.lang as Language;
const translations = { es, en };
const t = translations[lang];
---
<LayoutLanding lang={lang} t={t}>
  <Hero content={t.landingSecond.hero} second={true}/>
  <Products content={t.landingSecond.products}/>
  <Services content={t.landingSecond.services}/>
  <Map content={t.landingSecond.areas}/>
  <Reasons content={t.landingSecond.reasons}/>
  <Choose content={t.landingSecond.choose}/>
  <Customers content={t.landingSecond.customers}/>
  <Footer content={t.landingSecond.footer}/>
  <PopupAzul />
</LayoutLanding>