---
import CallLanding from '../../../components/CallLanding.astro';
import en from '../../../i18n/en';
import es from '../../../i18n/es';
import LayoutLanding from '../../../layouts/LayoutLanding.astro';
import CallAction from '../../../sections/go/CallAction.astro';
import Construction from '../../../sections/go/Construction.astro';
import Footer from '../../../sections/go/Footer.astro';
import Hero from '../../../sections/go/Hero.astro';
import Icons from '../../../sections/go/Icons.astro';
import Reviews from '../../../sections/go/Reviews.astro';
import Services from '../../../sections/go/Services.astro';
import Solutions from '../../../sections/go/Solutions.astro';
import type { Language } from '../../../types/language.type';
export function getStaticPaths() {
  return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }];
}

export const defaultRedirect = '/en';

const lang = Astro.params.lang as Language;
const translations = { es, en };
const t = translations[lang];
---
<LayoutLanding lang={lang} t={t}>
  <Hero content={t.landingFirst.hero}/>
  <Solutions content={t.landingFirst.solutions} second={false}/>
  <Reviews content={t.landingFirst.reviews} second={false}/>
  <CallAction content={t.landingFirst.callAction} />
  <Services content={t.landingFirst.private} />
  <Icons content={t.landingFirst.icons} />
  <Services content={t.landingFirst.public} />
  <Icons content={t.landingFirst.icons} />
  <Construction content={t.landingFirst.construction} />
  <Reviews content={t.landingFirst.reviews} second={true}/>
  <Solutions content={t.landingFirst.solutions} second={true}/>
  <Footer content={t.landingFirst.footer}/>
  <CallLanding content={t.landingFirst.hero}/>
</LayoutLanding>